# Copy this file to `.env` and fill only non-secret values for desktop runtime.
# Do NOT place DATABASE_URL / DB_PASSWORD in desktop builds.

BASE_URL=http://127.0.0.1:8080
DB_ACCESS_MODE=backend
SIGNAL_TRACKERS_API_URL=http://localhost:5224
SIGNAL_TRACKERS_BRIDGE_KEY=

# Optional runtime paths
# UPLOAD_FOLDER=
# OUTPUT_FOLDER=

# Optional service keys (keep empty in EXE builds)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# GROQ_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
